#!/usr/bin/env python3
"""filter-diff - keep or drop changed lines of a diffkit diff by pattern.

Reads a diffkit JSON document on stdin, matches PATTERN against changed
(added/removed) lines, and writes the filtered document to stdout. Hunks left
with no changes are dropped, as are files that had changes but no longer do.

Matching defaults to a literal, whole-line comparison with surrounding
whitespace ignored -- paste a line and it matches that line:
    * lines that MATCH are kept; `--exclude` / `-v` drops them instead;
    * `-E` / `--regexp` treats PATTERN as a regular expression;
    * `--substring` matches anywhere in the line, not just the whole line;
    * `--no-trim` compares the raw line, including leading/trailing whitespace;
    * `-i` / `--ignore-case` is case-insensitive.

Example (hide repeated `lorem ipsum` insertions, keep everything else):
    structured-diff main feature \\
        | filter-diff --exclude "lorem ipsum" \\
        | render-diff out.html
"""

import argparse
import os
import re
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
import _diffcommon as dc  # noqa: E402

PROG = "filter-diff"


def build_matcher(args):
    """Return a predicate matches(text) -> bool for one line's content.

    Defaults: a literal string, matched against the whole line, with leading and
    trailing whitespace ignored. Opt out with -E/--regexp, --substring, --no-trim.
    """
    pattern = args.pattern
    trim = not args.no_trim
    ignore = args.ignore_case
    whole_line = not args.substring

    if not args.regexp:
        needle = pattern.strip() if trim else pattern
        needle = needle.lower() if ignore else needle

        def matches(text):
            s = text.strip() if trim else text
            if ignore:
                s = s.lower()
            return s == needle if whole_line else needle in s
    else:
        flags = re.IGNORECASE if ignore else 0
        try:
            rx = re.compile(pattern, flags)
        except re.error as e:
            dc.die(PROG, f"invalid regex {pattern!r}: {e}")
        probe = rx.fullmatch if whole_line else rx.search

        def matches(text):
            s = text.strip() if trim else text
            return probe(s) is not None

    return matches


def filter_lines(lines, matches, sides, keep_matching):
    """Filter changed lines; context lines are always retained."""
    out = []
    for ln in lines:
        kind = ln["kind"]
        considered = (kind == "add" and "add" in sides) or \
                     (kind == "del" and "del" in sides)
        if not considered:
            out.append(ln)
            continue
        hit = matches(ln["text"])
        if hit == keep_matching:        # keep when (match == include-mode)
            out.append(ln)
    return out


def recount(hunk):
    """Recompute the @@ line counts from the lines actually kept."""
    old = sum(1 for ln in hunk["lines"] if ln["kind"] in ("context", "del"))
    new = sum(1 for ln in hunk["lines"] if ln["kind"] in ("context", "add"))
    hunk["old_count"], hunk["new_count"] = old, new


def main(argv=None):
    p = argparse.ArgumentParser(prog=PROG, description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("pattern", help="pattern matched against changed lines")
    p.add_argument("-v", "--exclude", action="store_true",
                   help="drop matching lines instead of keeping them")
    p.add_argument("-E", "--regexp", action="store_true",
                   help="treat PATTERN as a regular expression (default: literal string)")
    p.add_argument("--substring", action="store_true",
                   help="match anywhere in the line (default: the whole line must match)")
    p.add_argument("-i", "--ignore-case", action="store_true",
                   help="case-insensitive matching")
    p.add_argument("--no-trim", action="store_true",
                   help="compare the raw line (default: ignore surrounding whitespace)")
    p.add_argument("--side", choices=("both", "added", "removed"), default="both",
                   help="which changed lines to test (default: both)")
    p.add_argument("--keep-empty-files", action="store_true",
                   help="keep files even if filtering removed all their changes")
    p.add_argument("--pretty", action="store_true",
                   help="indent the JSON output (default: compact)")
    args = p.parse_args(argv)

    matches = build_matcher(args)
    sides = {"both": {"add", "del"}, "added": {"add"}, "removed": {"del"}}[args.side]
    keep_matching = not args.exclude

    doc = dc.read_doc(PROG)
    kept_files = []
    for f in doc.get("files", []):
        had_hunks = bool(f["hunks"])
        new_hunks = []
        for h in f["hunks"]:
            h["lines"] = filter_lines(h["lines"], matches, sides, keep_matching)
            if any(ln["kind"] in ("add", "del") for ln in h["lines"]):
                recount(h)
                new_hunks.append(h)
        f["hunks"] = new_hunks

        if new_hunks:
            kept_files.append(f)
        elif had_hunks:
            # Every changed line was filtered out: drop it unless asked to keep.
            if args.keep_empty_files:
                kept_files.append(f)
        else:
            # Structural-only change (rename/copy/mode/binary): it has no changed
            # lines to test against PATTERN, so it counts as *not matching*. A
            # non-match is dropped when keeping matches (the default) and kept when
            # excluding them (--exclude) -- so renames follow that same disposition.
            if not keep_matching or args.keep_empty_files:
                kept_files.append(f)

    doc["files"] = kept_files
    dc.write_doc(doc, pretty=args.pretty)


if __name__ == "__main__":
    main()
