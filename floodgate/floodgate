#!/usr/bin/env python3
"""floodgate - review the diff between two branches in your browser, with
persistent accept/reject/skip marks stored in a local .review file.

floodgate is built on diffkit: it shells out to `structured-diff` for the diff
and reuses `filter-diff` in the bulk-marking pipeline. The review unit is the
*hunk*; a file shows the roll-up of its hunks (and offers whole-file actions).

State lives in ./.review (JSON), keyed by the two compared commits, so a review
can be interrupted and resumed. Each hunk carries a content-derived `review_id`;
if the branch changes that hunk, its id changes and the old mark stops applying,
so the hunk correctly resurfaces as unreviewed.

Commands:
    floodgate review <base> <target>   start/resume; serve it in the browser
    floodgate diff                      emit the active review's diff as JSON
    floodgate accept                    mark stdin's changes accepted
    floodgate reject                    mark stdin's changes rejected
    floodgate skip                      mark stdin's changes skipped
    floodgate clear                     remove marks for stdin's changes
    floodgate status                    summarize the active review

The bulk-marking pipeline (filter-diff is from diffkit; it matches a literal,
whole-line, whitespace-trimmed pattern by default -- add --substring to match
anywhere in a line):
    floodgate diff | filter-diff --substring "TODO"   | floodgate reject
    floodgate diff | filter-diff --substring "vendor/" | floodgate skip

See README.md for details.
"""

import argparse
import hashlib
import html
import json
import os
import shutil
import subprocess
import sys
import threading
import webbrowser
from datetime import datetime
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

PROG = "floodgate"
REVIEW_FILE = ".review"
SCHEMA = "floodgate.review/v1"
STATUSES = ("accepted", "rejected", "skipped")  # plus the implicit "unreviewed"
ALL_VIEW_STATUSES = (*STATUSES, "unreviewed")
PIPE = subprocess.PIPE


# --------------------------------------------------------------------------- #
# Small helpers
# --------------------------------------------------------------------------- #
def die(msg, code=1):
    print(f"{PROG}: {msg}", file=sys.stderr)
    sys.exit(code)


def require(cmd):
    if shutil.which(cmd) is None:
        die(f"required command '{cmd}' not found on PATH "
            + ("(install diffkit)" if cmd in ("structured-diff", "filter-diff") else ""))


def now_iso():
    return datetime.now().astimezone().replace(microsecond=0).isoformat()


def esc(s):
    return html.escape(str(s), quote=False)


def resolve_visible(only, hide):
    """Resolve --only / --hide into the set of statuses to show (None = all)."""
    if only is not None and hide is not None:
        die("use only one of --only / --hide")

    def parse(spec, flag):
        names = {p.strip() for p in spec.split(",") if p.strip()}
        if not names:
            die(f"{flag}: no statuses given")
        bad = names - set(ALL_VIEW_STATUSES)
        if bad:
            die(f"{flag}: unknown status {', '.join(sorted(bad))} "
                f"(choose from {', '.join(ALL_VIEW_STATUSES)})")
        return names

    if only is not None:
        return parse(only, "--only")
    if hide is not None:
        return set(ALL_VIEW_STATUSES) - parse(hide, "--hide")
    return None


# --------------------------------------------------------------------------- #
# git / diff production (built on diffkit's structured-diff)
# --------------------------------------------------------------------------- #
def rev_parse(rev, repo="."):
    res = subprocess.run(["git", "-C", repo, "rev-parse", "--verify", f"{rev}^{{commit}}"],
                         text=True, stdout=PIPE, stderr=PIPE)
    if res.returncode != 0:
        die(f"cannot resolve revision {rev!r}:\n" + res.stderr.rstrip())
    return res.stdout.strip()


def merge_base(a, b, repo="."):
    res = subprocess.run(["git", "-C", repo, "merge-base", a, b],
                         text=True, stdout=PIPE, stderr=PIPE)
    return res.stdout.strip() if res.returncode == 0 else None


def produce(base, target, mode, repo="."):
    """Run diffkit's structured-diff and return the parsed diff document."""
    require("structured-diff")
    spec = [f"{base}...{target}"] if mode == "three-dot" else [base, target]
    res = subprocess.run(["structured-diff", "-C", repo, *spec],
                         text=True, stdout=PIPE, stderr=PIPE)
    if res.returncode != 0:
        die("structured-diff failed:\n" + res.stderr.rstrip())
    try:
        return json.loads(res.stdout)
    except json.JSONDecodeError as e:
        die(f"structured-diff did not emit JSON: {e}")


# --------------------------------------------------------------------------- #
# review_id + annotation
# --------------------------------------------------------------------------- #
def changed_texts(hunk):
    return [ln["text"] for ln in hunk.get("lines", []) if ln["kind"] in ("add", "del")]


def hunk_review_id(path, ordinal, hunk):
    """Stable id for a hunk: file path + ordinal + the changed-line text.

    Content-derived, so it is identical across re-runs and `-U` changes but
    changes when the hunk's content changes (then its old mark stops matching).
    The ordinal disambiguates two hunks with identical changed lines in one file.
    """
    h = hashlib.sha1()
    h.update(path.encode("utf-8", "surrogatepass"))
    h.update(b"\x00")
    h.update(str(ordinal).encode())
    for t in changed_texts(hunk):
        h.update(b"\x00")
        h.update(t.encode("utf-8", "surrogatepass"))
    return h.hexdigest()[:12]


def file_unit_id(f):
    """Id for a file with no hunks (rename / mode / binary) — its own unit."""
    h = hashlib.sha1()
    for part in (f.get("old_path") or "", f.get("new_path") or "", f.get("status") or ""):
        h.update(part.encode("utf-8", "surrogatepass"))
        h.update(b"\x00")
    return "f" + h.hexdigest()[:11]


def mark_status(marks, uid):
    m = marks.get(uid)
    if isinstance(m, dict) and m.get("status") in STATUSES:
        return m["status"]
    return "unreviewed"


def rollup(statuses):
    s = set(statuses)
    if not s or s == {"unreviewed"}:
        return "unreviewed"
    if len(s) == 1:
        return next(iter(s))
    if "unreviewed" in s:
        return "partial"
    return "mixed"


def annotate(doc, marks):
    """Stamp each hunk (and hunkless file) with review_id + review_status."""
    for f in doc.get("files", []):
        path = f.get("new_path") or f.get("old_path") or "?"
        f["review_id"] = file_unit_id(f)        # only used when there are no hunks
        for ordinal, h in enumerate(f.get("hunks") or []):
            h["review_id"] = hunk_review_id(path, ordinal, h)
            h["review_status"] = mark_status(marks, h["review_id"])
        if f.get("hunks"):
            f["review_status"] = rollup(h["review_status"] for h in f["hunks"])
        else:
            f["review_status"] = mark_status(marks, f["review_id"])
    return doc


def iter_units(doc):
    """Yield (file, hunk_or_None, review_id) for every reviewable unit."""
    for f in doc.get("files", []):
        if f.get("hunks"):
            for h in f["hunks"]:
                yield f, h, h.get("review_id")
        else:
            yield f, None, f.get("review_id")


def collect_units(doc):
    """(review_id, path) for every unit in a diff document read from stdin."""
    out = []
    for f, h, uid in iter_units(doc):
        path = f.get("new_path") or f.get("old_path") or "?"
        if uid:
            out.append((uid, path))
    return out


def tally(unit_ids, marks):
    c = {"accepted": 0, "rejected": 0, "skipped": 0, "unreviewed": 0, "total": len(unit_ids)}
    for uid in unit_ids:
        c[mark_status(marks, uid)] += 1
    return c


# --------------------------------------------------------------------------- #
# .review load / save / mutate
# --------------------------------------------------------------------------- #
def load_review(path=REVIEW_FILE):
    p = Path(path)
    if not p.exists():
        return None
    try:
        return json.loads(p.read_text())
    except Exception as e:
        die(f"{path} is not valid JSON: {e}")


def save_review(path, review):
    p = Path(path)
    tmp = p.with_name(p.name + ".tmp")
    tmp.write_text(json.dumps(review, indent=2, ensure_ascii=False) + "\n")
    os.replace(tmp, p)              # atomic within the directory


def apply_marks(review, pairs, status):
    """Set (or, for 'clear', remove) the mark for each (review_id, path)."""
    marks = review.setdefault("marks", {})
    for uid, path in pairs:
        if status == "clear":
            marks.pop(uid, None)
        else:
            marks[uid] = {"status": status, "path": path, "at": now_iso()}
    review["updated"] = now_iso()


