def display_path(f):
    op, np = f.get("old_path"), f.get("new_path")
    if f.get("status") in ("renamed", "copied") and op and np and op != np:
        return f'<span class="old">{esc(op)}</span> &rarr; {esc(np)}'
    return esc(np or op or "?")


def controls(active, scope):
    btns = [("accepted", "accept"), ("rejected", "reject"),
            ("skipped", "skip"), ("clear", "clear")]
    if scope == "file":
        btns = [("accepted", "accept all"), ("rejected", "reject all"),
                ("skipped", "skip all"), ("clear", "clear")]
    parts = ['<span class="controls">']
    for s, label in btns:
        cls = " active" if s == active and active != "unreviewed" else ""
        parts.append(f'<button data-s="{s}" data-scope="{scope}" class="{cls.strip()}">{label}</button>')
    parts.append("</span>")
    return "".join(parts)


def render_lines(lines, out):
    for ln in lines:
        kind = ln["kind"]
        cls = {"add": "add", "del": "del", "context": "ctx"}[kind]
        sign = {"add": "+", "del": "-", "context": ""}[kind]
        old = "" if ln["old_lineno"] is None else ln["old_lineno"]
        new = "" if ln["new_lineno"] is None else ln["new_lineno"]
        text = esc(ln["text"])
        if ln.get("no_newline"):
            text += '<span class="nonl"> \\ No newline at end of file</span>'
        out.append(
            f'<tr class="{cls}">'
            f'<td class="ln">{old}</td><td class="ln">{new}</td>'
            f'<td class="sign">{sign}</td><td>{text}</td></tr>'
        )


def _hidden(status, visible):
    """An inline style attr that hides a unit whose status isn't in `visible`."""
    return ' style="display:none"' if visible is not None and status not in visible else ""


def render_unit(h, out, visible):
    uid, st = h["review_id"], h["review_status"]
    head = f'@@ -{h["old_start"]},{h["old_count"]} +{h["new_start"]},{h["new_count"]} @@'
    if h["section"]:
        head += " " + h["section"]
    out.append(f'<div class="unit status-{st}" id="u-{uid}" data-id="{uid}" '
               f'data-status="{st}"{_hidden(st, visible)}>')
    out.append(f'<div class="hunkbar"><span>{esc(head)}</span>{controls(st, "unit")}</div>')
    out.append('<table class="diff"><tbody>')
    render_lines(h["lines"], out)
    out.append("</tbody></table></div>")


def render_structural_unit(f, out, visible):
    uid, st = f["review_id"], f["review_status"]
    if f["status"] == "mode" and f.get("old_mode") and f.get("new_mode"):
        note = f'mode changed {esc(f["old_mode"])} &rarr; {esc(f["new_mode"])}'
    elif f.get("binary"):
        note = "Binary file — content not shown."
    elif f["status"] in ("renamed", "copied"):
        sim = f.get("similarity")
        note = f'{f["status"]}' + (f' (similarity {sim}%)' if sim is not None else "")
    else:
        note = "No textual changes."
    out.append(f'<div class="unit status-{st}" id="u-{uid}" data-id="{uid}" '
               f'data-status="{st}"{_hidden(st, visible)}>')
    out.append(f'<div class="hunkbar"><span class="note">{note}</span>{controls(st, "unit")}</div>')
    out.append("</div>")


def render_file(f, out, visible):
    roll = f["review_status"]
    badge = f'<span class="badge b-{roll}" data-role="filebadge">{roll}</span>'
    # Hide the whole file when every one of its units is hidden by the filter.
    statuses = [h["review_status"] for h in f["hunks"]] if f.get("hunks") else [f["review_status"]]
    file_hidden = visible is not None and all(s not in visible for s in statuses)
    out.append(f'<details class="file" open{" style=\"display:none\"" if file_hidden else ""}>')
    out.append(f'<summary>{badge}<span class="path">{display_path(f)}</span>'
               f'{controls(None, "file")}</summary>')
    if f.get("hunks"):
        for h in f["hunks"]:
            render_unit(h, out, visible)
    else:
        render_structural_unit(f, out, visible)
    out.append("</details>")


def render_page(doc, review, base, target, moved, visible=None):
    units = list(iter_units(doc))
    c = tally([u[2] for u in units], review.get("marks", {}))
    out = ["<!doctype html>", '<html lang="en"><head>', '<meta charset="utf-8">',
           '<meta name="viewport" content="width=device-width, initial-scale=1">',
           f"<title>floodgate: {esc(base)} &rarr; {esc(target)}</title>",
           f"<style>{CSS}</style></head><body>"]
    out.append('<header class="page">')
    out.append(f"<h1>{esc(base)} &rarr; {esc(target)}</h1>")
    out.append('<div class="meta counts">'
               f'{c["total"]} changes &nbsp;·&nbsp; '
               f'<span class="c-accepted">accepted <b id="cnt-accepted">{c["accepted"]}</b></span> &nbsp;·&nbsp; '
               f'<span class="c-rejected">rejected <b id="cnt-rejected">{c["rejected"]}</b></span> &nbsp;·&nbsp; '
               f'<span class="c-skipped">skipped <b id="cnt-skipped">{c["skipped"]}</b></span> &nbsp;·&nbsp; '
               f'<span class="c-unreviewed">unreviewed <b id="cnt-unreviewed">{c["unreviewed"]}</b></span>'
               "</div>")
    if visible is not None:
        shown = ", ".join(s for s in ALL_VIEW_STATUSES if s in visible)
        out.append(f'<div class="meta">showing: {shown}</div>')
    out.append("</header><main>")
    if moved:
        out.append('<div class="banner">⚠ The branches moved since this review '
                   "started — hunks whose content changed reappear as unreviewed.</div>")
    if not doc.get("files"):
        out.append('<div class="note">No changes between these revisions.</div>')
    elif visible is not None and not any(
            (h["review_status"] if h is not None else f["review_status"]) in visible
            for f, h, _ in units):
        out.append(f'<div class="note">All {c["total"]} entries are hidden by the '
                   "current filter.</div>")
    for f in doc["files"]:
        render_file(f, out, visible)
    out.append("</main>")
    vis_js = "null" if visible is None else json.dumps(sorted(visible))
    out.append(f"<script>const FLOODGATE_VISIBLE = {vis_js};</script>")
    out.append(f"<script>{JS}</script>")
    out.append("</body></html>")
    return "\n".join(out) + "\n"


def error_page(exc):
    return ("<!doctype html><meta charset='utf-8'><body style='font-family:sans-serif;padding:24px'>"
            f"<h1>floodgate error</h1><pre>{esc(exc)}</pre>"
            "<p>Fix the problem and reload.</p></body>")


# --------------------------------------------------------------------------- #
# HTTP server
# --------------------------------------------------------------------------- #
class State:
    def __init__(self, review_path, base, target, mode, repo, review, moved, visible=None):
        self.review_path = Path(review_path)
        self.base, self.target, self.mode, self.repo = base, target, mode, repo
        self.review, self.moved, self.visible = review, moved, visible
        self.lock = threading.Lock()
        self.id_to_path, self.unit_ids = {}, []

    def produce_annotated(self):
        doc = produce(self.base, self.target, self.mode, self.repo)
        annotate(doc, self.review.get("marks", {}))
        return doc

    def cache_units(self, doc):
        self.id_to_path, self.unit_ids = {}, []
        for f, _h, uid in iter_units(doc):
            self.unit_ids.append(uid)
            self.id_to_path[uid] = f.get("new_path") or f.get("old_path") or "?"


class Handler(BaseHTTPRequestHandler):
    def log_message(self, *a):          # keep the console quiet
        pass

    def _send(self, code, body, ctype="text/html; charset=utf-8"):
        data = body.encode() if isinstance(body, str) else body
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        st = self.server.state
        if self.path in ("/", "/index.html"):
            with st.lock:
                # Reload marks so changes made by the CLI pipeline show on refresh.
                st.review = load_review(st.review_path) or st.review
                try:
                    doc = st.produce_annotated()
                except SystemExit as e:
                    self._send(500, error_page(e))
                    return
                st.cache_units(doc)
                page = render_page(doc, st.review, st.base, st.target, st.moved, st.visible)
            self._send(200, page)
        elif self.path == "/favicon.ico":
            self._send(204, b"")
        else:
            self._send(404, "not found")

    def do_POST(self):
        st = self.server.state
        if self.path != "/mark":
            self._send(404, "not found")
            return
        n = int(self.headers.get("Content-Length") or 0)
        try:
            payload = json.loads(self.rfile.read(n) or b"{}")
        except Exception:
            self._send(400, "bad json")
            return
        ids = payload.get("ids") or []
        status = payload.get("status")
        if status not in (*STATUSES, "clear"):
            self._send(400, "bad status")
            return
        with st.lock:
            review = load_review(st.review_path) or st.review
            apply_marks(review, [(i, st.id_to_path.get(i, "")) for i in ids], status)
            save_review(st.review_path, review)
            st.review = review
            res = "unreviewed" if status == "clear" else status
            body = {"ok": True,
                    "counts": tally(st.unit_ids, review.get("marks", {})),
                    "statuses": {i: res for i in ids}}
        self._send(200, json.dumps(body), "application/json")


def serve(state, host, port, open_browser):
    httpd = None
    for p in range(port, port + 20):
        try:
            httpd = ThreadingHTTPServer((host, p), Handler)
            port = p
            break
        except OSError:
            continue
    if httpd is None:
        die(f"no free port in {port}..{port + 19} on {host}")
    httpd.state = state
    # 0.0.0.0 / :: are bind-all addresses, not connectable ones, so show a
    # loopback URL to click and call out the wider binding separately.
    wildcard = host in ("0.0.0.0", "::", "")
    url = f"http://{'localhost' if wildcard else host}:{port}/"
    print(f"{PROG}: serving {url}  (Ctrl-C to stop)", flush=True)
    if wildcard:
        print(f"{PROG}: listening on all interfaces ({host}:{port}) — reach it via "
              "this host's address. No auth, so only do this on a trusted network.",
              flush=True)
    elif host not in ("127.0.0.1", "localhost", "::1"):
        print(f"{PROG}: bound to {host} (not loopback); the server has no auth.",
              flush=True)
    if open_browser:
        try:
            webbrowser.open(url)
        except Exception:
            pass
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print(f"\n{PROG}: stopped.")
    finally:
        httpd.server_close()


