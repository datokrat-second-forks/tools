# Commands
# --------------------------------------------------------------------------- #
def cmd_review(args):
    require("git")
    require("structured-diff")
    repo = args.directory
    base, target = args.base, args.target
    mode = "two-dot" if args.two_dot else "three-dot"
    visible = resolve_visible(args.only, args.hide)
    base_sha = rev_parse(base, repo)
    target_sha = rev_parse(target, repo)
    mb = merge_base(base, target, repo)
    if mode == "three-dot" and mb is None:
        die(f"{base} and {target} have no common ancestor; use --two-dot")

    path = Path(REVIEW_FILE)
    existing = load_review(path)
    review, moved = None, False
    if existing:
        same = (existing.get("base", {}).get("rev") == base
                and existing.get("target", {}).get("rev") == target
                and existing.get("mode", "three-dot") == mode)
        if same:
            review = existing
            moved = (review.get("target", {}).get("commit") != target_sha
                     or (mode == "three-dot" and review.get("merge_base") != mb))
        else:
            eb = existing.get("base", {}).get("rev")
            et = existing.get("target", {}).get("rev")
            print(f"{PROG}: {path} already holds a review for {eb} → {et} "
                  f"({existing.get('mode', 'three-dot')}), not {base} → {target} ({mode}).")
            try:
                ans = input("Discard it and start a new review? [y/N]: ").strip().lower()
            except EOFError:
                ans = ""
            if ans != "y":
                print(f"{PROG}: keeping the existing review; nothing changed.")
                return

    if review is None:
        review = {"schema": SCHEMA, "created": now_iso(), "marks": {}}
    review["base"] = {"rev": base, "commit": base_sha}
    review["target"] = {"rev": target, "commit": target_sha}
    review["merge_base"] = mb
    review["mode"] = mode
    review["updated"] = now_iso()
    save_review(path, review)

    # .review lives in the working directory; nudge to gitignore it so a stray
    # `git add -A` can't commit it. check-ignore: 0=ignored, 1=not, 128=no repo.
    if subprocess.run(["git", "check-ignore", "-q", REVIEW_FILE],
                      stdout=PIPE, stderr=PIPE).returncode == 1:
        print(f"{PROG}: hint — add '{REVIEW_FILE}' to .gitignore so it isn't committed.",
              flush=True)

    n = len(review.get("marks", {}))
    print(f"{PROG}: reviewing {base} → {target} ({mode}); state in {path}"
          + (f" ({n} existing mark{'s' if n != 1 else ''})" if n else ""), flush=True)
    if moved:
        print(f"{PROG}: note — branches moved since the last session; "
              "changed hunks reappear as unreviewed.", flush=True)
    serve(State(path, base, target, mode, repo, review, moved, visible),
          args.host, args.port, not args.no_open)


def cmd_diff(args):
    review = load_review()
    if review is None:
        die(f"no {REVIEW_FILE} here — run `floodgate review <base> <target>` first")
    doc = produce(review["base"]["rev"], review["target"]["rev"],
                  review.get("mode", "three-dot"))
    annotate(doc, review.get("marks", {}))
    json.dump(doc, sys.stdout, separators=(",", ":"), ensure_ascii=False)
    sys.stdout.write("\n")


def cmd_mark(args):
    review = load_review()
    if review is None:
        die(f"no {REVIEW_FILE} here — run `floodgate review …` first")
    data = sys.stdin.read()
    if not data.strip():
        die("no input on stdin — pipe `floodgate diff` (optionally through filter-diff)")
    try:
        doc = json.loads(data)
    except json.JSONDecodeError as e:
        die(f"stdin is not valid JSON: {e}")
    pairs = collect_units(doc)
    if not pairs:
        die("no review_id on stdin — pipe `floodgate diff`, not raw `structured-diff`")
    apply_marks(review, pairs, args.status)
    save_review(REVIEW_FILE, review)
    verb = {"accepted": "accepted", "rejected": "rejected",
            "skipped": "skipped", "clear": "cleared"}[args.status]
    print(f"{PROG}: {verb} {len(pairs)} change{'s' if len(pairs) != 1 else ''}.",
          file=sys.stderr)


def cmd_status(args):
    require("git")
    review = load_review()
    if review is None:
        die(f"no {REVIEW_FILE} here — run `floodgate review <base> <target>` first")
    base, target = review["base"]["rev"], review["target"]["rev"]
    mode = review.get("mode", "three-dot")
    cur_t = rev_parse(target)
    cur_mb = merge_base(base, target)
    moved = (review.get("target", {}).get("commit") != cur_t
             or (mode == "three-dot" and review.get("merge_base") != cur_mb))
    doc = produce(base, target, mode)
    annotate(doc, review.get("marks", {}))
    c = tally([uid for _f, _h, uid in iter_units(doc)], review.get("marks", {}))
    print(f"review: {base} → {target} ({mode})")
    print(f"  state file : {REVIEW_FILE}")
    print(f"  updated    : {review.get('updated', '?')}")
    print(f"  changes    : {c['total']}")
    print(f"  accepted   : {c['accepted']}")
    print(f"  rejected   : {c['rejected']}")
    print(f"  skipped    : {c['skipped']}")
    print(f"  unreviewed : {c['unreviewed']}")
    if moved:
        print("  WARNING    : branches moved since review start; "
              "changed hunks show as unreviewed again")


# --------------------------------------------------------------------------- #
# Entry point
# --------------------------------------------------------------------------- #
def build_parser():
    p = argparse.ArgumentParser(
        prog=PROG, description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd",
                           metavar="{review,diff,accept,reject,skip,clear,status}")

    pr = sub.add_parser("review", help="start/resume a review and open it in the browser")
    pr.add_argument("base")
    pr.add_argument("target")
    pr.add_argument("-C", "--directory", default=".", help="git repo dir (default: cwd)")
    pr.add_argument("--only", metavar="STATUSES",
                    help="show only these statuses (comma-separated: "
                         "accepted,rejected,skipped,unreviewed)")
    pr.add_argument("--hide", metavar="STATUSES",
                    help="hide these statuses (comma-separated); e.g. --hide accepted")
    pr.add_argument("--two-dot", action="store_true",
                    help="diff base..target (tips) instead of base...target (merge-base)")
    pr.add_argument("--host", default="127.0.0.1",
                    help="address to bind (default: 127.0.0.1; use 0.0.0.0 to reach "
                         "it from outside the container floodgate runs in)")
    pr.add_argument("-p", "--port", type=int, default=8765, help="port (default: 8765)")
    pr.add_argument("--no-open", action="store_true", help="don't open a browser")
    pr.set_defaults(func=cmd_review)

    pd = sub.add_parser("diff", help="emit the active review's diff (with ids+status) as JSON")
    pd.set_defaults(func=cmd_diff)

    for name, status, helptext in [
            ("accept", "accepted", "mark stdin's changes accepted"),
            ("reject", "rejected", "mark stdin's changes rejected"),
            ("skip", "skipped", "mark stdin's changes skipped"),
            ("clear", "clear", "remove marks for stdin's changes")]:
        sp = sub.add_parser(name, help=helptext)
        sp.set_defaults(func=cmd_mark, status=status)

    ps = sub.add_parser("status", help="summarize the active review")
    ps.set_defaults(func=cmd_status)
    return p


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    if not getattr(args, "func", None):
        parser.print_help()
        sys.exit(2)
    args.func(args)


if __name__ == "__main__":
    main()
